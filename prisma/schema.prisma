generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================
// ENUMS
// =========================

enum UserRole {
  user
  moderator
  admin
  super_admin
}

enum UserStatus {
  active
  inactive
  suspended
  deleted
}

enum PostType {
  corte
  comando
  ficha
  pregunta
  aporte
  libre
}

enum ReactionType {
  like
  dislike
  fire
  heart
  useful
}

enum NotificationType {
  info
  chat
  post
  comment
  reaction
  reputation
  system
}

enum ReputationEventType {
  post_created
  comment_created
  reaction_received
  useful_mark_received
  contribution_validated
  admin_adjustment
}

enum NotificationStatus {
  unread
  read
  archived
}

// =========================
// USERS
// =========================

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  password     String
  name         String
  username     String?    @unique
  avatarUrl    String?
  bio          String?
  phone        String?
  role         UserRole   @default(user)
  status       UserStatus @default(active)

  specialty    String?
  country      String?
  city         String?

  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  posts         Post[]
  comments      Comment[]
  reactions     Reaction[]
  messagesSent  Message[]  @relation("MessagesSent")
  messagesRecv  Message[]  @relation("MessagesReceived")

  reputation    Reputation?
  reputationEvents ReputationEvent[]
  notifications Notification[]

  @@index([email])
  @@index([username])
  @@index([role])
  @@index([status])
  @@index([createdAt])
}

// =========================
// POSTS
// =========================

model Post {
  id          String   @id @default(cuid())
  title       String
  content     String
  type        PostType
  metadata    Json?

  brand       String?
  model       String?
  year        Int?
  tags        String[]

  isPublished Boolean  @default(true)
  isValidated Boolean  @default(false)

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  comments    Comment[]
  reactions   Reaction[]

  @@index([userId])
  @@index([type])
  @@index([brand])
  @@index([model])
  @@index([year])
  @@index([isPublished])
  @@index([isValidated])
  @@index([createdAt])
}

// =========================
// COMMENTS
// =========================

model Comment {
  id        String   @id @default(cuid())
  content   String

  userId    String
  postId    String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([postId])
  @@index([createdAt])
}

// =========================
// REACTIONS
// =========================

model Reaction {
  id        String       @id @default(cuid())
  type      ReactionType

  userId    String
  postId    String

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post         @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
  @@index([type])
}

// =========================
// CHAT MESSAGES
// =========================

model Message {
  id          String   @id @default(cuid())
  content     String
  room        String   @default("global")

  senderId    String
  receiverId  String?

  sender      User     @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User?    @relation("MessagesReceived", fields: [receiverId], references: [id], onDelete: SetNull)

  isRead      Boolean  @default(false)
  readAt      DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([room])
  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

// =========================
// REPUTATION
// =========================

model Reputation {
  id        String   @id @default(cuid())

  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  points    Int      @default(0)
  level     Int      @default(1)
  rank      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([points])
  @@index([level])
}

// =========================
// REPUTATION EVENTS
// =========================

model ReputationEvent {
  id          String              @id @default(cuid())

  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        ReputationEventType
  points      Int
  reason      String?
  metadata    Json?

  createdAt   DateTime            @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// =========================
// NOTIFICATIONS
// =========================

model Notification {
  id        String             @id @default(cuid())

  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      NotificationType
  status    NotificationStatus @default(unread)

  title     String
  message   String
  metadata  Json?

  readAt    DateTime?
  createdAt DateTime           @default(now())

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}