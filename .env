# =========================
# APP CORE
# =========================
NODE_ENV=development
PORT=3000
APP_NAME=TecniRed Backend
APP_ENV=local
CLIENT_URL=http://localhost:5173
API_PREFIX=/api/v1

# =========================
# DATABASE / PRISMA
# =========================
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/tecnired?schema=public"

# =========================
# JWT AUTH
# =========================
JWT_SECRET=CHANGE_THIS_WITH_A_LONG_RANDOM_SECRET_MIN_64_CHARS
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_THIS_WITH_A_DIFFERENT_LONG_RANDOM_REFRESH_SECRET
JWT_REFRESH_EXPIRES_IN=30d

# =========================
# SECURITY
# =========================
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=200
TRUST_PROXY=false
SHOW_STACKTRACE=true

# =========================
# CORS
# =========================
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# =========================
# REDIS / CACHE
# =========================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# =========================
# QUEUES / BULLMQ
# =========================
QUEUE_REDIS_HOST=127.0.0.1
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_PASSWORD=
QUEUE_REDIS_TLS=false

# =========================
# SOCKET.IO
# =========================
SOCKET_CORS_ORIGIN=http://localhost:5173
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000

# =========================
# SMTP EMAIL SERVICE
# =========================
SMTP_HOST=smtp.tudominio.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@tudominio.com
SMTP_PASS=CHANGE_THIS_SMTP_PASSWORD
SMTP_FROM="TecniRed <no-reply@tudominio.com>"

# =========================
# FIREBASE ADMIN
# =========================
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# =========================
# FILE UPLOADS
# =========================
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# =========================
# LOGGING / OBSERVABILITY
# =========================
LOG_LEVEL=debug
ENABLE_EVENT_LOGS=true
ENABLE_REQUEST_LOGS=true

# =========================
# FEATURE FLAGS
# =========================
ENABLE_CHAT=true
ENABLE_NOTIFICATIONS=true
ENABLE_REPUTATION=true
ENABLE_POSTS=true
ENABLE_COMMENTS=true
ENABLE_REACTIONS=true
ENABLE_SEARCH=true
ENABLE_TOOLS=true

# =========================
# ANALYTICS / TRACKING
# =========================
ANALYTICS_ENABLED=true
TRACK_USER_EVENTS=true
TRACK_REPUTATION_CHANGES=true

# =========================
# CACHE STRATEGY
# =========================
CACHE_TTL_POSTS=60
CACHE_TTL_FEED=30
CACHE_TTL_USER=300
CACHE_TTL_SEARCH=120

# =========================
# PERFORMANCE
# =========================
REQUEST_TIMEOUT=30000
MAX_PAYLOAD_SIZE=10mb

# =========================
# JOBS
# =========================
ENABLE_REPUTATION_JOBS=true
ENABLE_NOTIFICATION_JOBS=true
JOB_CONCURRENCY=