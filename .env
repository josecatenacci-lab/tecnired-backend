
# =========================
# APP CORE
# =========================
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:5173

# =========================
# DATABASE (PRISMA)
# =========================
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/tecnired"

# =========================
# JWT AUTH
# =========================
JWT_SECRET=super_secret_key_change_me
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# =========================
# REDIS (CACHE + SOCKET + QUEUES)
# =========================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# =========================
# QUEUES (BULLMQ / WORKERS)
# =========================
QUEUE_REDIS_HOST=127.0.0.1
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_PASSWORD=

# =========================
# SOCKET.IO
# =========================
SOCKET_CORS_ORIGIN=http://localhost:5173
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000

# =========================
# SMTP EMAIL SERVICE
# =========================
SMTP_HOST=smtp.tudominio.com
SMTP_PORT=587
SMTP_USER=no-reply@tudominio.com
SMTP_PASS=your_smtp_password
SMTP_FROM="TecniRed <no-reply@tudominio.com>"

# =========================
# SECURITY
# =========================
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=200

BCRYPT_SALT_ROUNDS=10

# =========================
# FILE UPLOADS
# =========================
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# =========================
# LOGGING / OBSERVABILITY
# =========================
LOG_LEVEL=debug
ENABLE_EVENT_LOGS=true
ENABLE_REQUEST_LOGS=true

# =========================
# FEATURE FLAGS (MUY PRO)
# =========================
ENABLE_CHAT=true
ENABLE_NOTIFICATIONS=true
ENABLE_REPUTATION=true
ENABLE_POSTS=true
ENABLE_COMMENTS=true
ENABLE_REACTIONS=true

# =========================
# ANALYTICS / TRACKING
# =========================
ANALYTICS_ENABLED=true
TRACK_USER_EVENTS=true
TRACK_REPUTATION_CHANGES=true

# =========================
# CACHE STRATEGY
# =========================
CACHE_TTL_POSTS=60
CACHE_TTL_FEED=30
CACHE_TTL_USER=300

# =========================
# API VERSIONING
# =========================
API_PREFIX=/api/v1

# =========================
# ERROR HANDLING
# =========================
SHOW_STACKTRACE=true

# =========================
# PERFORMANCE
# =========================
REQUEST_TIMEOUT=30000
MAX_PAYLOAD_SIZE=10mb